import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from prophet import Prophet
plt.style.use("ggplot")

from prophet import Prophet
print("Prophet Installed Successfully")

df = pd.read_csv(r"C:\Users\91895\OneDrive\Desktop\NeuralRetail\data\processed\cleaned_retail.csv")

print("Dataset Shape:", df.shape)
df.head()

df.columns

df['InvoiceDate'] = pd.to_datetime(
    df['InvoiceDate']
)

df.info()

daily_sales = (df.groupby(df['InvoiceDate'].dt.date)['Revenue'].sum().reset_index())
daily_sales.columns = ['ds', 'y']
daily_sales['ds'] = pd.to_datetime(daily_sales['ds'])
daily_sales.head()

print("Rows:", daily_sales.shape[0])
daily_sales.describe()

plt.figure(figsize=(15,5))

plt.plot(
    daily_sales['ds'],
    daily_sales['y']
)

plt.title("Daily Revenue Trend")
plt.xlabel("Date")
plt.ylabel("Revenue (£)")
plt.show()

model = Prophet(
    yearly_seasonality=True,
    weekly_seasonality=True,
    daily_seasonality=False
)
model.fit(daily_sales)

future = model.make_future_dataframe(periods=90)
future.tail()

forecast = model.predict(future)

forecast[
    ['ds',
     'yhat',
     'yhat_lower',
     'yhat_upper']
].tail()

fig = model.plot(forecast)
plt.title("90-Day Revenue Forecast")
plt.show()

fig2 = model.plot_components(
    forecast
)

plt.show()

future_forecast = forecast[
    forecast['ds'] > daily_sales['ds'].max()
]

future_forecast.to_csv(
    "revenue_forecast.csv",
    index=False
)

print("Forecast saved successfully")

future_forecast[
    ['ds','yhat']
].head(10)

forecast[["ds","yhat","yhat_lower","yhat_upper"]].to_csv(
    "data/forecast.csv", index=False)

daily_sales.to_csv(
    "data/daily_sales.csv",index=False)

daily_sales.head()

